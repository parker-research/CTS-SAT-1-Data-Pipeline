# Copy to .env and fill in values before running the pipeline.

# ── SatNOGS ──────────────────────────────────────────────────────────────────
# Network API token — required.  Authenticate against network.satnogs.org.
# Obtain from: https://network.satnogs.org/accounts/api-auth-token/
SATNOGS_NETWORK_API_TOKEN=your_network_token_here

# DB API token — not currently used by the pipeline.
# Obtain from: https://db.satnogs.org/accounts/api-auth-token/
# SATNOGS_DB_API_TOKEN=your_db_token_here

# ── Satellite ─────────────────────────────────────────────────────────────────
SATELLITE_NORAD=69015

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://cts1:cts1@localhost:5432/cts1

# ── gr_satellites ─────────────────────────────────────────────────────────────
# Absolute path to the satellite YAML config
GR_SATELLITES_CONFIG=/absolute/path/to/cts1_data_pipeline/config/frontiersat.yml

# Number of parallel gr_satellites subprocesses
MAX_PARALLEL_DEMOD=4
